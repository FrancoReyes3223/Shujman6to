---
import config from 'virtual:starlight/user-config';

const FLAGS: Record<string, string> = { es: '🇦🇷', en: '🇺🇸' };

const currentLocale = Astro.locals.starlightRoute.locale ?? 'es';

// Build the equivalent path for each locale by swapping the locale segment.
function pathForLocale(targetLocale: string): string {
  const base = import.meta.env.BASE_URL.replace(/\/$/, '');
  const path = Astro.url.pathname;
  // Strip base prefix to work on the bare path
  const bare = path.startsWith(base) ? path.slice(base.length) : path;
  // bare starts with /es/... or /en/...
  const withNewLocale = bare.replace(/^\/(es|en)(\/|$)/, `/${targetLocale}$2`);
  return base + (withNewLocale || '/');
}
---

{config.isMultilingual && (
  <div class="lang-buttons">
    {Object.entries(config.locales).map(([code]) => (
      <a
        href={pathForLocale(code)}
        class:list={['lang-btn', { active: code === currentLocale }]}
      >
        <span>{FLAGS[code] ?? ''}</span>
        <span>{code.toUpperCase()}</span>
      </a>
    ))}
  </div>
)}

<style>
  .lang-buttons {
    display: flex;
    gap: 2px;
  }

  .lang-btn {
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.3rem 0.65rem;
    border-radius: 7px;
    background: transparent;
    color: var(--sl-color-gray-1);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    cursor: pointer;
    text-decoration: none;
    transition: background 0.15s, color 0.15s;
  }

  .lang-btn:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-white);
  }

  .lang-btn.active {
    background: var(--sl-color-accent);
    color: #fff;
    box-shadow: 0 0 10px var(--sl-color-accent-low);
  }
</style>
